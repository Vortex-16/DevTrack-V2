# ─── Database (Neon PostgreSQL) ───────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/devtrack?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/devtrack?sslmode=require&pgbouncer=true"

# ─── Clerk Authentication ──────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Your Clerk Frontend API (no trailing slash)
CLERK_ISSUER_URL="https://<your-instance>.clerk.accounts.dev"
# Auto-derived from CLERK_ISSUER_URL if not set
CLERK_JWKS_URL="https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json"

# ─── Security ─────────────────────────────────────────────────
# 64-char hex string (32 bytes) for AES-256-GCM GitHub token encryption
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="<generate-64-char-hex>"

# ─── GitHub OAuth ──────────────────────────────────────────────
# Create at https://github.com/settings/developers
# Callback URL: https://your-api-domain.com/api/v1/github/callback
GITHUB_CLIENT_ID="Ov23li..."
GITHUB_CLIENT_SECRET="..."
# Full URL where GitHub redirects after auth (must be HTTPS in production)
GITHUB_CALLBACK_URL="https://your-api-domain.com/api/v1/github/callback"
# Deep link base for mobile redirect after successful OAuth
MOBILE_DEEP_LINK_BASE="devtrack://oauth/github"

# ─── AI Providers ─────────────────────────────────────────────
# Primary: https://build.nvidia.com/nim (free tier)
NVIDIA_NIM_API_KEY="nvapi-..."
NVIDIA_NIM_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_NIM_MODEL="meta/llama-3.1-70b-instruct"

# Fallback: https://aistudio.google.com/app/apikey (free tier)
GEMINI_API_KEY="AIza..."

# Speed Inference: https://console.groq.com (free tier)
GROQ_API_KEY="gsk_..."
GROQ_BASE_URL="https://api.groq.com/openai/v1"
GROQ_MODEL="llama3-8b-8192"

# Voice Assistant: https://elevenlabs.io (free/paid voice TTS)
ELEVENLABS_API_KEY="el_..."
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"

# ─── Observability ────────────────────────────────────────────
SENTRY_DSN="https://...@sentry.io/..."

# ─── App ──────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001
API_URL="http://localhost:3001"
# Used for CORS — keep for web admin tools / swagger
# For mobile (React Native), CORS is not enforced by the OS
FRONTEND_URL="http://localhost:3000"

# Hoist Prisma client to root node_modules so all apps can resolve it
# without needing individual @prisma/client deps in each app
public-hoist-pattern[]=@prisma/client
public-hoist-pattern[]=prisma
public-hoist-pattern[]=@prisma/engines

# Strict peer dependency enforcement
strict-peer-dependencies=false
auto-install-peers=true

# Allow non-interactive node_modules purge (needed for CI / non-TTY)
confirmModulesPurge=false

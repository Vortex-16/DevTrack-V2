generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

enum SyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  RATE_LIMITED
}

enum InsightType {
  COMMIT_PATTERN
  LANGUAGE_TREND
  PRODUCTIVITY_SCORE
  GROWTH_SUMMARY
  REPO_ANALYSIS
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Mood {
  GREAT
  GOOD
  NEUTRAL
  TIRED
  BLOCKED
}

enum AuditAction {
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  USER_ROLE_CHANGED
  USER_PLAN_CHANGED
  PASSWORD_CHANGED
  TOKEN_REFRESHED
  GITHUB_CONNECTED
  GITHUB_DISCONNECTED
  PROJECT_CREATED
  PROJECT_DELETED
  ADMIN_ACTION
}

enum HackathonStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum HackathonRole {
  PARTICIPANT
  MENTOR
  JUDGE
  ORGANIZER
}

enum AnomalyType {
  PADDING
  COSMETIC
  DUPLICATE
  LOW_SIGNAL
  CRAMMING
  PURE_NOISE
  QUALITY_RISK
}

enum AnomalySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AnomalyStatus {
  OPEN
  REVIEWED
  DISMISSED
}

enum CommitType {
  FEATURE
  FIX
  REFACTOR
  TEST
  DOCS
  CHORE
}

// ─────────────────────────────────────────────────────────────
// USER & IDENTITY
// ─────────────────────────────────────────────────────────────

model User {
  id        String    @id @default(cuid())
  clerkId   String    @unique
  email     String    @unique
  username  String?   @unique
  plan      Plan      @default(FREE)
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete

  // Relations
  profile       Profile?
  githubAccount GitHubAccount?
  repositories  Repository[]
  syncJobs      SyncJob[]
  insights      Insight[]
  aiInsights    AIInsight[]
  streaks       Streak[]
  projects      Project[]
  learningLogs  LearningLog[]
  developerGraphs DeveloperGraph[]
  buildMemories   BuildMemory[]
  momentumSignals MomentumSignal[]
  skillConfidences SkillConfidence[]
  coachSessions    CoachSession[]
  developerReputation DeveloperReputation?
  hackathonParticipants HackathonParticipant[]

  @@index([clerkId])
  @@index([email])
  @@index([deletedAt])
}

model Profile {
  id        String  @id @default(cuid())
  userId    String  @unique
  bio       String?
  avatarUrl String?
  location  String?
  website   String?
  twitterUrl String?
  linkedinUrl String?
  isPublic  Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// GITHUB INTEGRATION
// ─────────────────────────────────────────────────────────────

model GitHubAccount {
  id             String    @id @default(cuid())
  userId         String    @unique
  githubId       String    @unique
  login          String
  encryptedToken String    // AES-256-GCM encrypted OAuth token
  tokenExpiresAt DateTime?
  scopes         String[]  // e.g. ["repo", "read:user"]
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([githubId])
}

model Repository {
  id           String    @id @default(cuid())
  userId       String
  githubRepoId String    @unique
  name         String
  fullName     String
  description  String?
  language     String?   // primary language
  isPrivate    Boolean   @default(false)
  isFork       Boolean   @default(false)
  starCount    Int       @default(0)
  forkCount    Int       @default(0)
  openIssueCount Int     @default(0)
  topics       String[]
  lastPushedAt DateTime?
  syncedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  commits      Commit[]
  repoAnalysis RepoAnalysis?

  @@index([userId])
  @@index([githubRepoId])
  @@index([language])
}

model Commit {
  id           String   @id @default(cuid())
  repositoryId String
  sha          String   @unique
  message      String
  authorLogin  String?
  authorEmail  String?
  committedAt  DateTime
  additions    Int      @default(0)
  deletions    Int      @default(0)
  changedFiles Int      @default(0)
  createdAt    DateTime @default(now())

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId])
  @@index([committedAt])
  @@index([authorLogin])
}

// ─────────────────────────────────────────────────────────────
// SYNC OBSERVABILITY
// ─────────────────────────────────────────────────────────────

model SyncJob {
  id        String     @id @default(cuid())
  userId    String
  status    SyncStatus @default(PENDING)
  traceId   String?    // correlates with structured logs
  startedAt DateTime?
  endedAt   DateTime?
  errorMsg  String?
  // Bounded meta — no open-ended blobs
  // { reposProcessed: number, commitsIngested: number, reposSkipped: number }
  meta      Json?
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([createdAt])
  @@index([traceId])
}

// ─────────────────────────────────────────────────────────────
// ANALYTICS & INSIGHTS
// ─────────────────────────────────────────────────────────────

model Insight {
  id          String      @id @default(cuid())
  userId      String
  type        InsightType
  // Schema varies per InsightType — validated at service layer
  data        Json
  generatedAt DateTime    @default(now())
  expiresAt   DateTime?   // null = permanent

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([generatedAt])
}

model Streak {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date // date only, no time
  committed Boolean  @default(false)
  mood      Mood?
  noteCount Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date]) // one record per user per day
  @@index([userId])
  @@index([date])
}

model RepoAnalysis {
  id           String   @id @default(cuid())
  repositoryId String   @unique
  summary      String   @db.Text
  // { "TypeScript": 80.5, "CSS": 12.3, "HTML": 7.2 }
  languages    Json
  complexity   Float?   // 0-10 score
  qualityScore Float?   // 0-10 score
  analyzedAt   DateTime @default(now())

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// AI SYSTEM
// ─────────────────────────────────────────────────────────────

model AIInsight {
  id         String   @id @default(cuid())
  userId     String
  provider   String   // "nvidia-nim" | "gemini"
  model      String   // e.g. "meta/llama-3.1-70b-instruct"
  prompt     String   @db.Text
  response   String   @db.Text
  tokensUsed Int?
  latencyMs  Int?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([provider])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// PROJECT MANAGEMENT
// ─────────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  userId      String
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  deadline    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?     // soft delete

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]
  projectDNA ProjectDNA?

  @@index([userId, status])
  @@index([deletedAt])
}

model Task {
  id          String     @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([dueDate])
}

// ─────────────────────────────────────────────────────────────
// LEARNING TRACKER
// ─────────────────────────────────────────────────────────────

model LearningLog {
  id       String   @id @default(cuid())
  userId   String
  topic    String
  notes    String?  @db.Text
  source   String?  // URL or resource name
  tags     String[]
  duration Int?     // minutes spent
  loggedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loggedAt])
  @@index([tags])
}

// ─────────────────────────────────────────────────────────────
// INTELLIGENCE LAYER (V2.1) — simple, extendable models
// Keep these small; services will implement logic and validation.
// ─────────────────────────────────────────────────────────────

model DeveloperGraph {
  id        String   @id @default(cuid())
  userId    String
  // flexible graph representation (nodes/edges) or vector metadata
  graph     Json
  score     Float?   // aggregated 0-100 score
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ProjectDNA {
  id         String   @id @default(cuid())
  projectId  String   @unique
  fingerprint Json    // architecture / language fingerprint
  summary    String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BuildMemory {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  content   String   @db.Text
  tags      String[]
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tags])
}

model MomentumSignal {
  id         String   @id @default(cuid())
  userId     String
  windowDays Int       @default(14)
  velocity   Float    // commits/day or similar metric
  burnoutRisk Float?  // 0-1
  computedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, computedAt])
}

model SkillConfidence {
  id        String   @id @default(cuid())
  userId    String
  skill     String
  confidence Float   // 0-1
  evidence   Json?   // pointers to commits, code samples, etc.
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skill])
}

model DeveloperReputation {
  id        String   @id @default(cuid())
  userId    String   @unique
  score     Float    // 0-100
  sources   Json?    // breakdown of contributors to score
  computedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoachSession {
  id        String   @id @default(cuid())
  userId    String
  prompt    String   @db.Text
  response  String   @db.Text
  model     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CommitQualityScore {
  id        String   @id @default(cuid())
  commitId  String   @unique
  score     Float    // 0-100
  details   Json?    // per-file or heuristic breakdown
  computedAt DateTime @default(now())

  @@index([commitId])
}

// ─────────────────────────────────────────────────────────────
// AUDIT & SECURITY
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id            String      @id @default(cuid())
  action        AuditAction
  performedBy   String      // User ID who performed the action
  targetUserId  String?     // User ID affected by the action (if applicable)
  targetResource String?    // Resource type (e.g., "Project", "Repository")
  targetResourceId String?  // Resource ID
  metadata      Json?       // Additional context (old/new values, IP, etc.)
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime    @default(now())

  @@index([performedBy])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// HACKATHON MODE (V2.2)
// ─────────────────────────────────────────────────────────────

model Hackathon {
  id          String          @id @default(cuid())
  name        String
  description String?         @db.Text
  status      HackathonStatus @default(DRAFT)
  startDate   DateTime
  endDate     DateTime
  createdBy   String          // User ID of organizer
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  teams              Team[]
  participants       HackathonParticipant[]
  scoringWeights     ScoringWeight[]
  progressSnapshots  TeamProgressSnapshot[]

  @@index([status])
  @@index([createdBy])
  @@index([startDate, endDate])
}

model Team {
  id           String   @id @default(cuid())
  hackathonId  String
  name         String
  repositoryId String?  // GitHub repository ID
  totalScore   Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  hackathon         Hackathon              @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  participants      HackathonParticipant[]
  progressSnapshots TeamProgressSnapshot[]
  anomalyEvents     AnomalyEvent[]
  commitAnalyses    CommitAnalysis[]

  @@index([hackathonId])
  @@index([totalScore])
}

model HackathonParticipant {
  id          String        @id @default(cuid())
  hackathonId String
  teamId      String?
  userId      String
  role        HackathonRole @default(PARTICIPANT)
  joinedAt    DateTime      @default(now())

  // Relations
  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  team      Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hackathonId, userId])
  @@index([hackathonId])
  @@index([teamId])
  @@index([userId])
  @@index([role])
}

model CommitAnalysis {
  id                   String     @id @default(cuid())
  teamId               String
  commitSha            String     @unique
  commitMessage        String     @db.Text
  authorUsername       String?
  committedAt          DateTime
  commitType           CommitType
  summary              String?    @db.Text
  progressValue        Float      // 0.0-1.0 from AI
  confidence           Float      // 0.0-1.0 from AI
  riskFlag             Boolean    @default(false)
  implementationScore  Float      @default(0)
  testScore            Float      @default(0)
  breadthScore         Float      @default(0)
  consistencyScore     Float      @default(0)
  qualityScore         Float      @default(0)
  totalScore           Float      @default(0)
  aiModel              String?    // Model used for analysis
  analyzedAt           DateTime   @default(now())

  // Relations
  team          Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  fileChanges   FileChange[]
  anomalyEvents AnomalyEvent[]

  @@index([teamId])
  @@index([commitSha])
  @@index([committedAt])
  @@index([authorUsername])
}

model FileChange {
  id                String   @id @default(cuid())
  commitAnalysisId  String
  filePath          String
  changeType        String   // added, modified, deleted
  additions         Int      @default(0)
  deletions         Int      @default(0)
  relevanceScore    Float    // 0.0-1.0 from file relevance filter
  createdAt         DateTime @default(now())

  // Relations
  commitAnalysis CommitAnalysis @relation(fields: [commitAnalysisId], references: [id], onDelete: Cascade)

  @@index([commitAnalysisId])
  @@index([relevanceScore])
}

model TeamProgressSnapshot {
  id                   String   @id @default(cuid())
  teamId               String
  hackathonId          String
  snapshotAt           DateTime @default(now())
  totalScore           Float
  implementationScore  Float
  testScore            Float
  breadthScore         Float
  consistencyScore     Float
  qualityScore         Float
  anomalyCount         Int      @default(0)
  riskLevel            String?  // LOW, MEDIUM, HIGH, CRITICAL

  // Relations
  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@index([teamId, snapshotAt])
  @@index([hackathonId])
}

model AnomalyEvent {
  id               String          @id @default(cuid())
  teamId           String
  commitAnalysisId String?
  anomalyType      AnomalyType
  severity         AnomalySeverity
  status           AnomalyStatus   @default(OPEN)
  autoDetected     Boolean         @default(true)
  description      String?         @db.Text
  reviewedBy       String?         // User ID
  resolution       String?         @db.Text
  createdAt        DateTime        @default(now())
  reviewedAt       DateTime?

  // Relations
  team           Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  commitAnalysis CommitAnalysis? @relation(fields: [commitAnalysisId], references: [id], onDelete: SetNull)

  @@index([teamId, severity, status])
  @@index([status])
  @@index([createdAt])
}

model ScoringWeight {
  id          String   @id @default(cuid())
  hackathonId String
  dimension   String   // implementation, test, breadth, consistency, quality
  weight      Float    // 0.0-1.0
  version     Int      @default(1)
  createdBy   String   // User ID
  createdAt   DateTime @default(now())

  // Relations
  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@unique([hackathonId, dimension, version])
  @@index([hackathonId])
}

model FileRelevanceCache {
  id              String   @id @default(cuid())
  filePathHash    String   @unique
  repositoryId    String?
  relevanceScore  Float
  ruleBreakdown   Json?    // Breakdown of which rules contributed to score
  computedAt      DateTime @default(now())

  @@index([filePathHash])
  @@index([repositoryId])
}
